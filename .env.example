# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0XXXXXXXXX      # right-click channel → Copy channel ID

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=1BxiM...   # last segment of the folder's URL
GOOGLE_SERVICE_ACCOUNT_FILE=/home/youruser/slack-to-drive/service_account.json

# Gmail (use an App Password, not your real password)
# https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional
EMAIL_TO=admin@rockymountaincoop.com
STATE_FILE=/home/youruser/slack-to-drive/state.json
LOG_FILE=/home/youruser/slack-to-drive/slack-to-drive.log
INITIAL_LOOKBACK_DAYS=30          # how far back to go on the very first run
